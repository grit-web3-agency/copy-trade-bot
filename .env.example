# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# Solana RPC (Helius free tier)
HELIUS_API_KEY=your_helius_api_key_here
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Devnet RPC (used when user mode=devnet; must be a devnet endpoint)
DEVNET_RPC=https://api.devnet.solana.com

# Network (devnet only for MVP)
SOLANA_NETWORK=devnet

# Copy Policy Defaults
DEFAULT_MAX_TRADE_SIZE_SOL=0.1
DEFAULT_SLIPPAGE_BPS=100
